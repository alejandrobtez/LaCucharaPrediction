# ================================================
# CREDENCIALES DEL PROYECTO "LA CUCHARA"
# Copia este archivo como .env y rellena los valores reales.
# ================================================

# --- Azure SQL Database ---
DB_SERVER=lacucharaserver.database.windows.net
DB_NAME=lacucharabbdd
DB_USER=TU_USUARIO_AQUI
DB_PASSWORD=TU_PASSWORD_AQUI
DB_DRIVER={ODBC Driver 17 for SQL Server}

# --- Azure OpenAI (AI Foundry) ---
# Modelo desplegado: gpt-4o-mini
AZURE_OPENAI_ENDPOINT=https://TU-RECURSO-openai.services.ai.azure.com/
AZURE_OPENAI_KEY=TU_KEY_AQUI
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# --- Azure OCR (Document Intelligence) ---
AZURE_OCR_ENDPOINT=https://TU-RECURSO-ocr.cognitiveservices.azure.com/
AZURE_OCR_KEY=TU_KEY_AQUI

# --- Azure ML Endpoint (Predicción de demanda) ---
# Modelo: predicciondeman9 (AutoML XGBoost, entrenado en Azure ML Studio)
AZURE_ML_ENDPOINT=https://TU-ENDPOINT.ukwest.inference.ml.azure.com/score
AZURE_ML_KEY=TU_KEY_AQUI
